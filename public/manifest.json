{
  "manifest_version": 3,
  "name": "DevX New Tab",
  "version": "0.1.0",
  "description": "Keyboard-first new tab: fuzzy-search open tabs, bookmarks, and recently closed; save workspaces; attach notes to URLs.",
  "icons": {
    "16": "Frame 7.png",
    "48": "Frame 8.png",
    "128": "Frame 9.png"
  },
  "permissions": [
    "tabs",
    "bookmarks",
    "favicon",
    "storage",
    "sessions"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "chrome_url_overrides": {
    "newtab": "newTab.html"
  }
}
