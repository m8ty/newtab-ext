{
  "manifest_version": 3,
  "name": "DevX New Tab Page",
  "version": "0.0.0.1",
  "description": "A convenient new tab page for searching tabs, bookmarks, and more.",
  "icons": {
    "16": "Frame 7.png",
    "48": "Frame 8.png",
    "128": "Frame 9.png"
  },
  "permissions": [
    "tabs",
    "bookmarks",
    "favicon",
    "storage",
    "sessions"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "chrome_url_overrides": {
    "newtab": "newTab.html"
  }
}
